
# Google Cloud Vision API Key (server-side only — never VITE_ prefixed)
GOOGLE_CLOUD_VISION_API_KEY=your_google_api_key_here

# Supabase (VITE_ prefix exposes to browser — safe, RLS protects data)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase (server-side — for Netlify Functions JWT validation)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Directory to watch for new scans (Local script only)
WATCH_DIR=C:\Scans

# Secret Key (Required for Netlify Trigger protection)
SECRET_KEY=MySecretKey123

# Email Configuration (SMTP) - For sending Emails
# Example for Gmail: smtp.gmail.com (Use App Password if 2FA is on)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Hours Counter Bot
EMAIL_TO=recipient_email@example.com

# IMAP Configuration - For reading Emails (Cloud function only)
IMAP_HOST=imap.gmail.com
